# Security
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# Local runtime and generated artifacts
swarm_runs/
reports/
Modulars/swarm_runs/
Modulars/reports/
Modulars_legacy/swarm_runs/
Modulars_legacy/reports/
.phoenix/
*.db

# Python caches and test caches
__pycache__/
**/__pycache__/
.pytest_cache/
**/.pytest_cache/

# Local app temp files
.files/
**/.files/

# Chainlit auto-generated translations
**/.chainlit/translations/

# Frozen legacy (local archive only — replaced by conveyor_v2)
Modulars_legacy/

# Conveyor v2
conveyor_v2/*.egg-info/
conveyor_v2/build/
conveyor_v2/dist/
conveyor_v2/.pytest_cache/
conveyor_v2/src/conveyor/__pycache__/
conveyor_v2/src/conveyor/**/__pycache__/
