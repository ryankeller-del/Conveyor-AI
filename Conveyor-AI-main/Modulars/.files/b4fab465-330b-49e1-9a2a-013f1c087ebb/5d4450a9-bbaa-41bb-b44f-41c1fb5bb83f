class ScoutBot:
    """
    Technical Architect that refines research queries based on discovered stack.
    """
    def __init__(self, project_stack):
        self.project_stack = project_stack
    
    def refine_query(self, query):
        """
        Refine the research query based on the project stack.
        """
        stack_specific_context = {
            'Unity': f"Unity game development with C# scripting, UnityEditor, and Unity APIs",
            'Python': f"Python development with relevant frameworks and libraries",
            'Web': f"Web development with JavaScript, HTML, and relevant frameworks",
            'Unknown': f"General software development"
        }
        
        context = stack_specific_context.get(self.project_stack, stack_specific_context['Unknown'])
        refined_query = f"{query}. Context: {context}. Provide information specific to {self.project_stack} development if applicable."
        
        return refined_query

