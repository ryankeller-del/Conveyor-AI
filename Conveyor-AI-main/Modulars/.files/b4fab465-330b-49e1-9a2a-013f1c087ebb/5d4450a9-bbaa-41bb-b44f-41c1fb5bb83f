import os
import sys
import chainlit as cl

# Environment Discovery Function
def discover_project_stack():
    """
    Scans the current folder for .cs, .py, or .js files to determine project stack.
    Returns: A string indicating the project type ('Unity', 'Python', 'Web', or 'Unknown')
    """
    current_dir = os.getcwd()
    file_extensions = ['.cs', '.py', '.js']
    project_types = {'Unity': 0, 'Python': 0, 'Web': 0}
    
    for root, _, files in os.walk(current_dir):
        for file in files:
            if any(file.endswith(ext) for ext in file_extensions):
                if file.endswith('.cs'):
                    project_types['Unity'] += 1
                elif file.endswith('.py'):
                    project_types['Python'] += 1
                elif file.endswith('.js'):
                    project_types['Web'] += 1
    
    # Determine the dominant project type
    max_count = max(project_types.values())
    if max_count == 0:
        return 'Unknown'
    
    for project_type, count in project_types.items():
        if count == max_count:
            return project_type

# Null-safe generation wrapper for modular_belt.py compatibility
def safe_generate(agent, *args, **kwargs):
    """
    Null-safe wrapper for Agent.generate method to prevent UI crashes.
    """
    try:
        if hasattr(agent, 'generate') and callable(agent.generate):
            return agent.generate(*args, **kwargs)
        else:
            return "Error: Agent does not have a generate method"
    except Exception as e:
        return f"Error in generation: {str(e)}"

