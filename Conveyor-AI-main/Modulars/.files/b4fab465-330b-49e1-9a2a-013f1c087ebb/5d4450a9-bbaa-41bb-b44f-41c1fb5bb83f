# Chainlit Application Setup
@cl.on_chat_start
async def start_chat():
    """
    Initialize the chat and display 'Shadow Factory Online' message.
    """
    # Discover project stack
    project_stack = discover_project_stack()
    
    # Initialize agents
    scout_bot = ScoutBot(project_stack)
    loader_bot = LoaderBot()
    local_coder = LocalCoder(project_stack)
    
    # Store agents in session for later use
    cl.user_session.set("scout_bot", scout_bot)
    cl.user_session.set("loader_bot", loader_bot)
    cl.user_session.set("local_coder", local_coder)
    cl.user_session.set("project_stack", project_stack)
    
    # Send welcome message
    welcome_message = f"Shadow Factory Online\n\nDetected project stack: {project_stack}\n\nAvailable commands:\n- research [query]: Conduct research\n- code [prompt]: Generate code"
    await cl.Message(content=welcome_message).send()

@cl.on_message
async def main(message: str):
    """
    Handle incoming messages and route to appropriate agents.
    """
    # Get agents from session
    scout_bot = cl.user_session.get("scout_bot")
    loader_bot = cl.user_session.get("loader_bot")
    local_coder = cl.user_session.get("local_coder")
    project_stack = cl.user_session.get("project_stack")
    
    # Process message based on content
    if message.lower().startswith("research"):
        query = message[8:].strip()
        refined_query = scout_bot.refine_query(query)
        research_result = await loader_bot.research(refined_query)
        await cl.Message(content=research_result).send()
    elif message.lower().startswith("code"):
        prompt = message[5:].strip()
        # Use safe_generate wrapper
        generated_code = safe_generate(local_coder, prompt)
        await cl.Message(content=f"```{generated_code}```").send()
    else:
        await cl.Message(content="Unknown command. Try 'research [query]' or 'code [prompt]'").send()

if __name__ == "__main__":
    # Get port from command line arguments or default to 8000
    port = int(sys.argv[1]) if len(sys.argv) > 1 else 8000
    chainlit.run(app_path="app_v2.py", port=port)
