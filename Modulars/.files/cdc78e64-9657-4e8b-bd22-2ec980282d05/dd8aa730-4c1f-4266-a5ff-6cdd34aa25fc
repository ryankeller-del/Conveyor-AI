# app_v2.py
import sys
import os

def discover_environment():
    """Scan current directory for .cs, .py, .js files"""
    environment = []
    for filename in os.listdir('.'):
        if filename.endswith(('.cs', '.py', '.js')):
            environment.append(filename)
    return environment

def main():
    # Port selection logic
    port = 8000
    if '--port' in sys.argv:
        port_index = sys.argv.index('--port')
        if port_index + 1 < len(sys.argv):
            port = int(sys.argv[port_index + 1])
    
    # Discover environment
    env_files = discover_environment()
    
    # Update LocalCoder prompt to Systems Engineer role
    prompt = """
You are now acting as a Systems Engineer. Your coding style must adapt to the discovered environment:
{env_files}
Please generate Python code that:
1. Implements robust error handling
2. Follows PEP 8 guidelines
3. Includes comprehensive logging
4. Maintains backward compatibility with existing systems
5. Can be deployed in containerized environments
"""
    print(prompt.format(env_files='\n'.join(env_files)))

if __name__ == "__main__":
    main()
