python
import os
from typing import Any, Dict

from dotenv import load_dotenv
from flask import Flask, render_template_string

load_dotenv()

app = Flask(__name__)

@app.route('/')
def home():
    return render_template_string(SWARM_MONITOR_TEMPLATE)

SWARM_MONITOR_TEMPLATE = """
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Codex Swarm Monitor</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #0d1117;
        --panel: #111826;
        --panel-soft: #182235;
        --text: #e6edf3;
        --muted: #9fb0c3;
        --accent: #ff4f8b;
        --border: #243044;
        --good: #38d996;
        --warn: #f0b429;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        background: linear-gradient(180deg, #090c12 0%, #0d1117 100%);
        color: var(--text);
        font-family: "Segoe UI", Arial, sans-serif;
      }
      header {
        position: sticky;
        top: 0;
        z-index: 2;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        padding: 1rem 1.5rem;
        background: rgba(9, 12, 18, 0.92);
        border-bottom: 1px solid var(--border);
        backdrop-filter: blur(10px);
      }
      h1 {
        margin: 0;
        font-size: 1.1rem;
        letter-spacing: 0.04em;
      }
      .sub {
        color: var(--muted);
        font-size: 0.85rem;
        margin-top: 0.2rem;
      }
      .status {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.75rem;
        padding: 1rem 1.5rem 0.5rem;
      }
      .card {
        background: rgba(17, 24, 38, 0.9);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 0.75rem 0.9rem;
      }
      .label {
        color: var(--muted);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.35rem;
      }
      .value {
        font-size: 0.95rem;
        line-height: 1.35;
        word-break: break-word;
      }
      main {
        padding: 0.5rem 1.5rem 1.5rem;
      }
      .panel {
        background: rgba(17, 24, 38, 0.88);
        border: 1px solid var(--border);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 24px 48px rgba(0, 0, 0, 0.2);
      }
      .panel-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        padding: 0.9rem 1rem;
        background: rgba(24, 34, 53, 0.9);
        border-bottom: 1px solid var(--border);
      }
      .panel-head strong {
        font-size: 0.96rem;
      }
      .panel-head span {
        color: var(--muted);
        font-size: 0.82rem;
      }
      .transcript {
        max-height: calc(100vh - 290px);
        overflow: auto;
        padding: 1rem;
      }
      .entry {
        padding: 0.8rem 0.85rem;
        margin-bottom: 0.75rem;
        background: rgba(9, 14, 24, 0.85);
        border: 1px solid var(--border);
        border-radius: 12px;
      }
      .entry:nth-child(odd) {
        background: rgba(14, 19, 30, 0.9);
      }
      .entry .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        color: var(--muted);
        font-size: 0.74rem;
        margin-bottom: 0.35rem;
      }
      .entry .message {
        white-space: pre-wrap;
        line-height: 1.45;
      }
      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
      }
    </style>
  </head>
  <body>

    <header>
      <h1>Codex Swarm Monitor</h1>
    </header>

    <main>
      <div class="status">
        <div class="card">
          <div class="label">Swarm Agents</div>
          <div class="value">0 Active</div>
        </div>
        
        <div class="card">
          <div class="label">Network Status</div>
          <div class="value">{{ network_status }}</div>
        </div>
      </div>

      <div class="panel">
        <div class="panel-head">
          <strong>System Logs</strong>
          <span>{{ log_count }} logs</span>
        </div>
        <div class="transcript">
          {% for entry in system_logs %}
            <div class="entry">
              <div class="meta">
                <span class="pill">
                  <span>{{ entry['timestamp'] }}</span>
                </span>
                <span>{{ entry['level'] }}</span>
              </div>
              <div class="message">{{ entry['message'] }}</div>
            </div>
          {% endfor %}
        </div>
      </div>
    </main>

  </body>
</html>
"""

@app.route('/status')
def status():
    network_status = check_network_status()
    system_logs = fetch_system_logs()
    log_count = len(system_logs)
    
    return {
        'network_status': network_status,
        'system_logs': system_logs,
        'log_count': log_count
    }

def check_network_status() -> str:
    try:
        # Simulate a network status check
        socket.create_connection(("www.google.com", 80))
        return "Online"
    except OSError:
        return "Offline"

def fetch_system_logs() -> list:
    # Simulate fetching system logs
    return [
        {"timestamp": "2023-10-01T12:00:00Z", "level": "INFO", "message": "System started."},
        {"timestamp": "2023-10-01T12:01:00Z", "level": "ERROR", "message": "Failed to connect to database."}
    ]


This code includes updates to the home page template to display network status and system logs. It also adds a `/status` route to provide the data for these sections. The `check_network_status` function simulates checking the network connection, and `fetch_system_logs` simulates fetching log entries.

