# Conveyor v2 — environment variables
# Copy to .env and fill in before running.

# API Keys (at least one required)
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Local Ollama (optional — agents fall back to cloud if unavailable)
OLLAMA_HOST=localhost
OLLAMA_PORT=11434

# Conveyor configuration
CONVEYOR_HOME=

# Logging
CONVEYOR_LOG_LEVEL=INFO
